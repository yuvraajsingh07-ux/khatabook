# ============================================================
# Required Environment Variables — set these in Railway dashboard
# ============================================================

# PostgreSQL connection string from Supabase
# Go to: Supabase Dashboard → your project → Settings → Database → Connection String
# Choose "URI" tab → use the "Direct connection" string (Port 5432)
# It looks like: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres?sslmode=require

# Railway injects PORT automatically at runtime (typically 3000 or your service's port)
# No need to set this manually on Railway
PORT=8080

# Node environment
NODE_ENV=production
